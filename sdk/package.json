{
  "name": "burp-rpc",
  "version": "1.0.2",
  "description": "Control Burp Suite programmatically from Node.js over gRPC — proxy history, repeater, site map, and more.",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "proto",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm run build"
  },
  "keywords": [
    "burp",
    "burp-suite",
    "burpsuite",
    "grpc",
    "rpc",
    "security",
    "pentesting",
    "pentest",
    "repeater",
    "proxy",
    "web-security",
    "montoya"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/shero4/burp-rpc.git",
    "directory": "sdk"
  },
  "homepage": "https://github.com/shero4/burp-rpc#readme",
  "bugs": {
    "url": "https://github.com/shero4/burp-rpc/issues"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.9.14",
    "@grpc/proto-loader": "^0.7.10"
  },
  "devDependencies": {
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
